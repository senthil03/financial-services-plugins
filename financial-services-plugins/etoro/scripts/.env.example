# 🛡️ Antigravity Email Notification Configuration
# Rename this file to '.env' and place it in the same directory as regulatory_news_monitor.py.
# Rest assured, '.env' is explicitly ignored by your .gitignore and will NEVER be committed to GitHub.

# 1. Your SMTP sender address (we recommend using the same address you want alerts to go to)
SENDER_EMAIL=senthil_03@yahoo.com

# 2. Your Yahoo App Password (16 characters, abcd efgh ijkl mnop)
# Note: You MUST generate an App Password. Standard login passwords will be rejected by Yahoo.
SENDER_PASSWORD=your_yahoo_app_password

# 3. SMTP Server settings (defaults to Yahoo's official settings)
SMTP_SERVER=smtp.mail.yahoo.com
SMTP_PORT=587
